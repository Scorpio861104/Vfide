# Production Environment Configuration
# Copy this file to .env.production for production deployments
# IMPORTANT: Never commit .env.production to version control

# ============================================================================
# REQUIRED - Application will not start without these
# ============================================================================

# Set to true to deploy a self-contained frontend-only build (no backend env hard requirements).
# When true, missing DATABASE_URL/JWT_SECRET do not fail env validation in CI/Vercel.
# Canonical server-side flag: FRONTEND_SELF_CONTAINED (read by lib/contracts.ts and lib/validateProduction.ts)
FRONTEND_SELF_CONTAINED=true

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=VFIDE
NEXT_PUBLIC_APP_URL=https://vfide.io
APP_ORIGIN=https://vfide.io

# Blockchain Configuration
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_EXPLORER_URL=https://basescan.org
NEXT_PUBLIC_IS_TESTNET=false

# Database (PostgreSQL)
# REQUIRED only when FRONTEND_SELF_CONTAINED=false and backend API routes are used
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:5432/vfide_production

# Authentication
# REQUIRED only when FRONTEND_SELF_CONTAINED=false and backend auth is used
# Generate with: openssl rand -base64 32
JWT_SECRET=YOUR_SECURE_JWT_SECRET_MINIMUM_32_CHARACTERS
# Zero-downtime rotation: set to old JWT_SECRET value when rotating.
# New tokens use JWT_SECRET; old tokens verified against PREV_JWT_SECRET.
# Remove after 24 h (all old tokens will have expired).
# PREV_JWT_SECRET=

# Rate Limiting (Upstash Redis)
# REQUIRED: Sign up at https://upstash.com and create Redis database
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# WalletConnect/Wagmi (Web3 Wallet Integration)
# REQUIRED: Get project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ============================================================================
# SMART CONTRACT ADDRESSES - Deploy to mainnet and update these
# ============================================================================
# REQUIRED: Deploy contracts using hardhat deploy scripts and fill in addresses
# Leave empty until contracts are deployed, then update here

NEXT_PUBLIC_DAO_ADDRESS=0x0000000000000000000000000000000000000000
# DEPRECATED: use NEXT_PUBLIC_VFIDE_TOKEN_ADDRESS (below) — kept for backwards compatibility
NEXT_PUBLIC_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# DEPRECATED: use NEXT_PUBLIC_DAO_TIMELOCK_ADDRESS (below) — kept for backwards compatibility
NEXT_PUBLIC_TIMELOCK_ADDRESS=0x0000000000000000000000000000000000000000
# DEPRECATED: no longer used by lib/contracts.ts — kept for backwards compatibility
NEXT_PUBLIC_GOVERNOR_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
# DEPRECATED: use NEXT_PUBLIC_COUNCIL_MANAGER_ADDRESS (below) — kept for backwards compatibility
NEXT_PUBLIC_COUNCIL_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_OWNER_CONTROL_PANEL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PROOF_LEDGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ESCROW_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FEE_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000
# NEXT_PUBLIC_WITHDRAWAL_QUEUE_ADDRESS removed: WithdrawalQueue.sol deleted per B-11 (dead code cleanup)

# Core token & vault
NEXT_PUBLIC_VFIDE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_HUB_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_RECOVERY_CLAIM_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_IMPLEMENTATION=cardbound

# Seer (ProofScore oracle)
NEXT_PUBLIC_SEER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SEER_AUTONOMOUS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SEER_GUARDIAN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SEER_SOCIAL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SEER_VIEW_ADDRESS=0x0000000000000000000000000000000000000000

# Governance
NEXT_PUBLIC_DAO_TIMELOCK_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COUNCIL_ELECTION_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COUNCIL_SALARY_ADDRESS=0x0000000000000000000000000000000000000000

# Badges & reputation
NEXT_PUBLIC_BADGE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BADGE_NFT_ADDRESS=0x0000000000000000000000000000000000000000

# Commerce & payments
NEXT_PUBLIC_VFIDE_COMMERCE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MERCHANT_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COMMERCE_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TRUST_GATEWAY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SUBSCRIPTION_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000

# Lending (P2P term loans & flash loans)
NEXT_PUBLIC_TERM_LOAN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FLASH_LOAN_ADDRESS=0x0000000000000000000000000000000000000000

# Security & guardian
NEXT_PUBLIC_GUARDIAN_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GUARDIAN_LOCK_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PANIC_GUARD_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_EMERGENCY_BREAKER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FRAUD_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Token economics
NEXT_PUBLIC_BURN_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DUTY_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LIQUIDITY_INCENTIVES_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STABLECOIN_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Vaults (specialized)
NEXT_PUBLIC_SANCTUM_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ECOSYSTEM_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ECOSYSTEM_VAULT_VIEW_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DEV_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Operations
NEXT_PUBLIC_PAYROLL_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000

# Testnet faucet (devnet/testnet only — leave zero on mainnet)
NEXT_PUBLIC_FAUCET_ADDRESS=0x0000000000000000000000000000000000000000

# Frontend-only mode flag (client-side alias; FRONTEND_SELF_CONTAINED is the authoritative server-side key).
# Both are read by lib/contracts.ts and lib/validateProduction.ts via `?? process.env.NEXT_PUBLIC_FRONTEND_ONLY`.
NEXT_PUBLIC_FRONTEND_ONLY=false

# ============================================================================
# OPTIONAL - Features will be disabled without these
# ============================================================================

# Avatar Storage (S3-Compatible)
# Optional but recommended: Leave empty to disable avatar uploads
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_PUBLIC_BASE_URL=https://your-bucket.s3.amazonaws.com
# Optional: custom endpoint for S3-compatible providers (Cloudflare R2, etc.)
# S3_ENDPOINT=https://your-r2-endpoint.com
# S3_FORCE_PATH_STYLE=false

# Error Tracking (Sentry)
# Optional but recommended: Sign up at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Analytics (Google Analytics)
# Optional: Get measurement ID from Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Two-Factor Authentication - Email (SendGrid)
# Optional: Required only if enabling email-based 2FA
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@vfide.io
SENDGRID_FROM_NAME=VFIDE

# Two-Factor Authentication - SMS (Twilio)
# Optional: Required only if enabling SMS-based 2FA
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Admin Addresses
# Optional: Comma-separated list of wallet addresses with admin privileges
ADMIN_ADDRESS=0x0000000000000000000000000000000000000000
ADMIN_ADDRESSES=0x0000000000000000000000000000000000000000,0x1111111111111111111111111111111111111111

# WebSocket Server
NEXT_PUBLIC_WEBSOCKET_URL=wss://ws.vfide.io
NEXT_PUBLIC_WEBSOCKET_PATH=/socket.io

# API Configuration
NEXT_PUBLIC_API_URL=https://api.vfide.io
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_GOVERNANCE=true
NEXT_PUBLIC_ENABLE_COUNCIL=true
NEXT_PUBLIC_ENABLE_BADGES=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Social Links
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/vfide
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/vfide
NEXT_PUBLIC_GITHUB_URL=https://github.com/Scorpio861104/Vfide

# Performance
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true

# Security
NEXT_PUBLIC_CSP_ENABLED=true
NEXT_PUBLIC_RATE_LIMIT_ENABLED=true
# Required in production to avoid predictable IP hashes in logs
# LOG_IP_HASH_SALT=replace-with-unique-random-salt-min-16-chars
