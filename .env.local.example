# ============================================
# REQUIRED: Local Validation Baseline
# ============================================
# These satisfy `lib/validateProduction.ts` for local/CI parity checks.
FRONTEND_SELF_CONTAINED=true
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=local_walletconnect_project_id
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.basescan.org
NEXT_PUBLIC_IS_TESTNET=true

# Optional app URL (auto-inferred locally if omitted)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional backend-only settings (uncomment only if using server API features)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vfide_dev
# JWT_SECRET=local-dev-only-change-me

# ============================================
# REQUIRED: WalletConnect Configuration
# ============================================
# Get your WalletConnect Project ID from: https://cloud.walletconnect.com/
NEXT_PUBLIC_WAGMI_PROJECT_ID=your_walletconnect_project_id_here

# ============================================
# REQUIRED: Network Configuration
# ============================================
# Chain ID for Base Sepolia testnet
NEXT_PUBLIC_CHAIN_ID=84532

# RPC endpoint for Base Sepolia
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# ⚠️ CRITICAL: This is required for health checks to pass!
# For local development, use zero address
# For production, use your deployed main contract address
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================
# OPTIONAL: Contract Addresses
# ============================================
# VFide Token (ERC20)
NEXT_PUBLIC_VFIDE_TOKEN_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e

# Core Governance Contracts
NEXT_PUBLIC_DAO_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_COUNCIL_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_COUNCIL_ELECTION_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_COUNCIL_SALARY_ADDRESS=0x1234567890123456789012345678901234567890

# Timelock Contracts
NEXT_PUBLIC_DAO_TIMELOCK_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_DAO_TIMELOCK_V2_ADDRESS=0x1234567890123456789012345678901234567890

# Vesting & Vault Contracts
NEXT_PUBLIC_VESTING_VAULT_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_DEV_RESERVE_VESTING_VAULT_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_ECOSYSTEM_VAULT_ADDRESS=0x1234567890123456789012345678901234567890

# Staking & Rewards
NEXT_PUBLIC_STAKING_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_DUTY_DISTRIBUTOR_ADDRESS=0x1234567890123456789012345678901234567890

# Badge & Registry
NEXT_PUBLIC_BADGE_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_BADGE_REGISTRY_ADDRESS=0x1234567890123456789012345678901234567890

# Escrow & Subscription
NEXT_PUBLIC_ESCROW_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_SUBSCRIPTION_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890

# Token Launch
NEXT_PUBLIC_TOKEN_LAUNCH_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890

# Emergency Control
NEXT_PUBLIC_EMERGENCY_CONTROL_ADDRESS=0x1234567890123456789012345678901234567890

# ============================================
# OPTIONAL: Feature Flags
# ============================================
# Enable sanctum (mystical reflection chamber)
NEXT_PUBLIC_ENABLE_SANCTUM=false

# Enable beta features
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# ============================================
# OPTIONAL: API & External Services
# ============================================
# Block explorer URL
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://sepolia.basescan.org

# IPFS gateway (for metadata)
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/

# ============================================
# DEPLOYMENT INSTRUCTIONS FOR VERCEL
# ============================================
# 1. Copy this file to .env.local for local development
# 2. For Vercel deployment, set environment variables in:
#    Project Settings → Environment Variables
# 3. Required variables (MUST set):
#    - NEXT_PUBLIC_WAGMI_PROJECT_ID
#    - NEXT_PUBLIC_CHAIN_ID
#    - NEXT_PUBLIC_RPC_URL
# 4. Optional: Contract addresses (use deployed addresses)
# 5. Deploy and verify build succeeds

# ============================================
# SECURITY NOTES
# ============================================
# - Never commit .env.local to git (already in .gitignore)
# - NEXT_PUBLIC_* variables are exposed to the browser
# - Do not put secrets in NEXT_PUBLIC_* variables
# - Use server-side API routes for sensitive operations

# ============================================
# OPTIONAL: Sentry Error Tracking
# ============================================
# Get your Sentry DSN from: https://sentry.io/
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxx@o0.ingest.sentry.io/0
# SENTRY_DSN=https://xxxxxxxxxxxxxxxx@o0.ingest.sentry.io/0
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================
# OPTIONAL: App Version for Releases
# ============================================
# NEXT_PUBLIC_APP_VERSION=1.0.0
