# ============================================
# REQUIRED: Local Validation Baseline
# ============================================
# These satisfy `lib/validateProduction.ts` for local/CI parity checks.
FRONTEND_SELF_CONTAINED=true
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=local_walletconnect_project_id
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_DEPLOYMENT_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.basescan.org
NEXT_PUBLIC_IS_TESTNET=true

# Optional app URL (auto-inferred locally if omitted)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required for local validation baseline (replace with real values when using backend features)
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/vfide_dev
JWT_SECRET=YOUR_SECURE_JWT_SECRET_MINIMUM_32_CHARACTERS

# ============================================
# REQUIRED: WalletConnect Configuration
# ============================================
# Get your WalletConnect Project ID from: https://cloud.walletconnect.com/
# Canonical key: NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID (used by lib/wagmi.ts)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ============================================
# REQUIRED: Network Configuration
# ============================================
# Chain ID for Base Sepolia testnet
NEXT_PUBLIC_CHAIN_ID=84532
# Chain ID used by deployment profile checks (must match NEXT_PUBLIC_CHAIN_ID in production)
NEXT_PUBLIC_DEPLOYMENT_CHAIN_ID=84532

# RPC endpoint for Base Sepolia
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# ⚠️ CRITICAL: This is required for health checks to pass!
# For local development, use zero address
# For production, use your deployed main contract address
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================
# OPTIONAL: Contract Addresses
# ============================================
# VFide Token (ERC20)
NEXT_PUBLIC_VFIDE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STABLECOIN_REGISTRY_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_MERCHANT_PORTAL_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_VAULT_HUB_ADDRESS=0x1234567890123456789012345678901234567890
# Vault implementation mode: cardbound (default) or uservault
NEXT_PUBLIC_VAULT_IMPLEMENTATION=cardbound
NEXT_PUBLIC_SEER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_SEER_VIEW_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_VFIDE_COMMERCE_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_PAYROLL_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_SANCTUM_VAULT_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_DEV_VAULT_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_TRUST_GATEWAY_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_BADGE_NFT_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_SECURITY_HUB_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_GUARDIAN_REGISTRY_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_GUARDIAN_LOCK_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_PANIC_GUARD_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_EMERGENCY_BREAKER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_BURN_ROUTER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_LIQUIDITY_INCENTIVES_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_SEER_SOCIAL_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_VAULT_REGISTRY_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_COMMERCE_ESCROW_ADDRESS=0x1234567890123456789012345678901234567890

# Core Governance Contracts
NEXT_PUBLIC_DAO_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_COUNCIL_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_COUNCIL_ELECTION_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_COUNCIL_SALARY_ADDRESS=0x1234567890123456789012345678901234567890

# Timelock Contracts
NEXT_PUBLIC_DAO_TIMELOCK_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_DAO_TIMELOCK_V2_ADDRESS=0x1234567890123456789012345678901234567890

# Vesting & Vault Contracts
NEXT_PUBLIC_VESTING_VAULT_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_DEV_RESERVE_VESTING_VAULT_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_ECOSYSTEM_VAULT_ADDRESS=0x1234567890123456789012345678901234567890

# Staking & Rewards
NEXT_PUBLIC_STAKING_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_DUTY_DISTRIBUTOR_ADDRESS=0x1234567890123456789012345678901234567890

# Badge & Registry
NEXT_PUBLIC_BADGE_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_BADGE_REGISTRY_ADDRESS=0x1234567890123456789012345678901234567890

# Escrow & Subscription
NEXT_PUBLIC_ESCROW_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_SUBSCRIPTION_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_WITHDRAWAL_QUEUE_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_FEE_DISTRIBUTOR_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_PROOF_LEDGER_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_OWNER_CONTROL_PANEL_ADDRESS=0x1234567890123456789012345678901234567890

# Seer Modules (optional, enables live reason-code event timelines)
NEXT_PUBLIC_SEER_AUTONOMOUS_ADDRESS=0x1234567890123456789012345678901234567890
NEXT_PUBLIC_SEER_GUARDIAN_ADDRESS=0x1234567890123456789012345678901234567890

# Token Launch
NEXT_PUBLIC_TOKEN_LAUNCH_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890

# ============================================
# OPTIONAL: Testnet Faucet
# ============================================
# Address of the deployed VFIDETestnetFaucet contract (testnet only)
NEXT_PUBLIC_FAUCET_ADDRESS=0x0000000000000000000000000000000000000000
# Server-side private key of the operator wallet that triggers faucet claims
# NEVER expose this in a NEXT_PUBLIC_ variable
# FAUCET_OPERATOR_PRIVATE_KEY=0x_your_operator_private_key_here

# Emergency Control
NEXT_PUBLIC_EMERGENCY_CONTROL_ADDRESS=0x1234567890123456789012345678901234567890

# ============================================
# OPTIONAL: Feature Flags
# ============================================
# Enable sanctum (mystical reflection chamber)
NEXT_PUBLIC_ENABLE_SANCTUM=false

# Enable beta features
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# ============================================
# OPTIONAL: API & External Services
# ============================================
# Block explorer URL (legacy alias removed; use NEXT_PUBLIC_EXPLORER_URL above)

# IPFS gateway (for metadata)
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/

# ============================================
# DEPLOYMENT INSTRUCTIONS FOR VERCEL
# ============================================
# 1. Copy this file to .env.local for local development
# 2. For Vercel deployment, set environment variables in:
#    Project Settings → Environment Variables
# 3. Required variables (MUST set):
#    - NEXT_PUBLIC_WAGMI_PROJECT_ID
#    - NEXT_PUBLIC_CHAIN_ID
#    - NEXT_PUBLIC_RPC_URL
# 4. Optional: Contract addresses (use deployed addresses)
# 5. Deploy and verify build succeeds

# ============================================
# SECURITY NOTES
# ============================================
# - Never commit .env.local to git (already in .gitignore)
# - NEXT_PUBLIC_* variables are exposed to the browser
# - Do not put secrets in NEXT_PUBLIC_* variables
# - Use server-side API routes for sensitive operations

# ============================================
# OPTIONAL: Block Explorer Verification (Etherscan / Basescan)
# ============================================
# BASESCAN_API_KEY=your-basescan-api-key
# ETHERSCAN_API_KEY=your-etherscan-api-key
# POLYGONSCAN_API_KEY=your-polygonscan-api-key

# ============================================
# OPTIONAL: Deployer Private Key (NEVER commit real values)
# ============================================
# PRIVATE_KEY=0x_your_deployer_private_key_here

# ============================================
# OPTIONAL: Redis / Upstash (rate limiting, caching)
# ============================================
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# OPTIONAL: WebSocket Server
# ============================================
# NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ============================================
# OPTIONAL: Session Key Configuration
# ============================================
# Maximum session key duration in seconds (default: 86400 = 24h)
# NEXT_PUBLIC_SESSION_KEY_MAX_DURATION_SECONDS=86400

# ============================================
# OPTIONAL: Subgraph & Analytics
# ============================================
# NEXT_PUBLIC_SUBGRAPH_URL=https://api.studio.thegraph.com/query/xxxxx/vfide/version/latest
# NEXT_PUBLIC_VFIDE_WETH_POOL_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================
# OPTIONAL: Push Notifications (VAPID)
# ============================================
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ============================================
# OPTIONAL: Ramp / Fiat On-ramp
# ============================================
# NEXT_PUBLIC_RAMP_API_KEY=your-ramp-api-key

# ============================================
# OPTIONAL: JWT Rotation (see lib/auth/jwt.ts)
# ============================================
# During rotation: set PREV_JWT_SECRET to old value, JWT_SECRET to new value
# Remove PREV_JWT_SECRET after 24h when all old tokens expire
# PREV_JWT_SECRET=old-secret-during-rotation-only

# ============================================
# OPTIONAL: Sentry Error Tracking
# ============================================
# Get your Sentry DSN from: https://sentry.io/
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxx@o0.ingest.sentry.io/0
# SENTRY_DSN=https://xxxxxxxxxxxxxxxx@o0.ingest.sentry.io/0
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================
# OPTIONAL: App Version for Releases
# ============================================
# NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================
# OPTIONAL: Server-side Only (never NEXT_PUBLIC_)
# ============================================
# RPC_URL=https://sepolia.base.org
# MERCHANT_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000
# VFIDE_TRUST_PROXY_HEADERS=false
