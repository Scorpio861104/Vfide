    "inputs": [
      { "name": "vault", "type": "address" },
      { "name": "recoveryId", "type": "string" }
    ],
    "outputs": []
  },
  {
    "name": "setEmailRecovery",
    "type": "function",
    "stateMutability": "nonpayable",
    "inputs": [
      { "name": "vault", "type": "address" },
      { "name": "emailHash", "type": "bytes32" }
    ],
    "outputs": []
  },
  {
    "name": "setUsername",
    "type": "function",
    "stateMutability": "nonpayable",
    "inputs": [
      { "name": "vault", "type": "address" },
      { "name": "username", "type": "string" }
    ],
    "outputs": []
