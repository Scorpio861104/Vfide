// SPDX-License-Identifier: MIT
pragma solidity 0.8.30;

import "forge-std/Test.sol";
import "../../contracts-prod/VFIDECommerce.sol";
import "../../contracts-prod/mocks/ERC20Mock.sol";
import "../../contracts-prod/mocks/VaultHubMock.sol";
import "../../contracts-prod/mocks/SecurityHubMock.sol";
import "../../contracts-prod/mocks/LedgerMock.sol";
import "../../contracts-prod/mocks/SeerMock.sol";

contract VFIDECommerceTest is Test {
    MerchantRegistry public merchantRegistry;
    CommerceEscrow public escrow;
    ERC20Mock public token;
    VaultHubMock public vaultHub;
    SecurityHubMock public securityHub;
    LedgerMock public ledger;
    SeerMock public seer;
    
    address constant DAO = address(0x1);
    address constant MERCHANT = address(0x2);
    address constant BUYER = address(0x3);
    address constant CHARITY = address(0x4);
    
    function setUp() public {
        // Deploy mocks
        token = new ERC20Mock("Mock Token", "MOCK");
        vaultHub = new VaultHubMock();
        securityHub = new SecurityHubMock();
        ledger = new LedgerMock();
        seer = new SeerMock();
        
        // Set minimum score for merchants
        seer.setMinForMerchant(100);
        
        // Deploy contracts
        merchantRegistry = new MerchantRegistry(
            DAO,
            address(token),
            address(vaultHub),
            address(seer),
            address(securityHub),
            address(ledger)
        );
        
        escrow = new CommerceEscrow(
            address(merchantRegistry),
            address(token),
            address(vaultHub),
            address(securityHub),
            address(ledger),
            CHARITY
        );
        
        // Setup merchant with good score
        seer.setScore(MERCHANT, 150);
        
        // Give buyer tokens
        token.mint(BUYER, 1_000_000e18);
    }
    
    // ============ MERCHANT REGISTRY FUZZ TESTS ============
    
    /// @notice Fuzz test: Only addresses with sufficient score can become merchants
    function testFuzz_MerchantScoreRequirement(uint16 score) public {
        address user = address(uint160(score + 1000));
        seer.setScore(user, score);
        
        vm.prank(user);
        
        if (score < seer.minForMerchant()) {
            vm.expectRevert(COM_NotAllowed.selector);
        }
        
        merchantRegistry.addMerchant(bytes32(uint256(1)));
    }
    
    /// @notice Fuzz test: Merchant auto-suspend after threshold refunds
    function testFuzz_AutoSuspendOnRefunds(uint8 numRefunds) public {
        vm.assume(numRefunds > 0 && numRefunds <= 20);
        
        // Add merchant
        vm.prank(MERCHANT);
        merchantRegistry.addMerchant(bytes32(uint256(1)));
        
        uint8 threshold = merchantRegistry.autoSuspendRefunds();
        
        // Simulate refunds
        for (uint256 i = 0; i < numRefunds; i++) {
            merchantRegistry._noteRefund(MERCHANT);
        }
        
        // Check status
        (,, MerchantRegistry.Status status,,, ) = merchantRegistry.merchants(MERCHANT);
        
        if (numRefunds >= threshold) {
            assertEq(uint8(status), uint8(MerchantRegistry.Status.SUSPENDED), "Should be auto-suspended");
        } else {
            assertEq(uint8(status), uint8(MerchantRegistry.Status.ACTIVE), "Should remain active");
        }
    }
    
    /// @notice Fuzz test: Merchant auto-suspend after threshold disputes
    function testFuzz_AutoSuspendOnDisputes(uint8 numDisputes) public {
        vm.assume(numDisputes > 0 && numDisputes <= 20);
        
        // Add merchant
        vm.prank(MERCHANT);
        merchantRegistry.addMerchant(bytes32(uint256(1)));
        
        uint8 threshold = merchantRegistry.autoSuspendDisputes();
        
        // Simulate disputes
        for (uint256 i = 0; i < numDisputes; i++) {
            merchantRegistry._noteDispute(MERCHANT);
        }
        
        // Check status
        (,, MerchantRegistry.Status status,,, ) = merchantRegistry.merchants(MERCHANT);
        
        if (numDisputes >= threshold) {
            assertEq(uint8(status), uint8(MerchantRegistry.Status.SUSPENDED), "Should be auto-suspended");
        } else {
            assertEq(uint8(status), uint8(MerchantRegistry.Status.ACTIVE), "Should remain active");
        }
    }
    
    /// @notice Fuzz test: Cannot add merchant twice
    function testFuzz_CannotAddMerchantTwice(bytes32 metaHash1, bytes32 metaHash2) public {
        // Add merchant first time
        vm.startPrank(MERCHANT);
        merchantRegistry.addMerchant(metaHash1);
        
        // Try to add again
        vm.expectRevert(COM_AlreadyMerchant.selector);
        merchantRegistry.addMerchant(metaHash2);
        
        vm.stopPrank();
    }
    
    // ============ ESCROW FUZZ TESTS ============
    
    /// @notice Fuzz test: Escrow state transitions are valid
    function testFuzz_EscrowStateTransitions(uint256 amount, uint32 timeLimit) public {
        vm.assume(amount > 0 && amount < 1_000_000e18);
        vm.assume(timeLimit > 0 && timeLimit < 365 days);
        
        // Setup merchant
        vm.prank(MERCHANT);
        merchantRegistry.addMerchant(bytes32(uint256(1)));
        
        // Buyer creates escrow
        vm.startPrank(BUYER);
        token.approve(address(escrow), amount);
        
        uint256 orderId = escrow.createOrder(MERCHANT, amount, timeLimit, "item123");
        
        // Verify initial state
        (,,,,,, CommerceEscrow.State state,,,) = escrow.orders(orderId);
        assertEq(uint8(state), uint8(CommerceEscrow.State.ACTIVE), "Should start ACTIVE");
        
        vm.stopPrank();
        
        // Merchant can complete
        vm.prank(MERCHANT);
        escrow.complete(orderId);
        
        (,,,,,, state,,,) = escrow.orders(orderId);
        assertEq(uint8(state), uint8(CommerceEscrow.State.COMPLETED), "Should be COMPLETED");
    }
    
    /// @notice Fuzz test: Escrow amounts are handled correctly
    function testFuzz_EscrowAmountHandling(uint256 amount) public {
        vm.assume(amount > 0 && amount < 1_000_000e18);
        
        // Setup merchant
        vm.prank(MERCHANT);
        merchantRegistry.addMerchant(bytes32(uint256(1)));
        
        // Buyer creates escrow
        vm.startPrank(BUYER);
        token.approve(address(escrow), amount);
        
        uint256 balBefore = token.balanceOf(BUYER);
        uint256 orderId = escrow.createOrder(MERCHANT, amount, 7 days, "item");
        uint256 balAfter = token.balanceOf(BUYER);
        
        // Buyer should have paid
        assertEq(balBefore - balAfter, amount, "Amount not transferred");
        
        // Escrow should hold funds
        assertEq(token.balanceOf(address(escrow)), amount, "Escrow doesn't hold funds");
        
        vm.stopPrank();
        
        // Complete and check merchant receives
        address merchantVault = vaultHub.vaultOf(MERCHANT);
        uint256 merchantBalBefore = token.balanceOf(merchantVault);
        
        vm.prank(MERCHANT);
        escrow.complete(orderId);
        
        uint256 merchantBalAfter = token.balanceOf(merchantVault);
        assertEq(merchantBalAfter - merchantBalBefore, amount, "Merchant didn't receive payment");
    }
    
    /// @notice Fuzz test: Cannot complete order before it exists
    function testFuzz_CannotCompleteNonexistentOrder(uint256 fakeOrderId) public {
        vm.assume(fakeOrderId > 0);
        
        vm.prank(MERCHANT);
        vm.expectRevert();
        escrow.complete(fakeOrderId);
    }
    
    /// @notice Fuzz test: Refund window works correctly
    function testFuzz_RefundWindow(uint32 timeLimit, uint32 timeElapsed) public {
        vm.assume(timeLimit > 0 && timeLimit < 365 days);
        vm.assume(timeElapsed > 0 && timeElapsed < 400 days);
        
        // Setup
        vm.prank(MERCHANT);
        merchantRegistry.addMerchant(bytes32(uint256(1)));
        
        uint256 amount = 100e18;
        
        vm.startPrank(BUYER);
        token.approve(address(escrow), amount);
        uint256 orderId = escrow.createOrder(MERCHANT, amount, timeLimit, "item");
        vm.stopPrank();
        
        // Advance time
        vm.warp(block.timestamp + timeElapsed);
        
        // Try to refund
        vm.prank(BUYER);
        
        if (timeElapsed < timeLimit) {
            vm.expectRevert(COM_TooEarly.selector);
        }
        
        escrow.refund(orderId);
    }
    
    /// @notice Fuzz test: Dispute resolution distributes funds correctly
    function testFuzz_DisputeResolution(uint256 amount, uint8 buyerShare) public {
        vm.assume(amount > 100 && amount < 1_000_000e18);
        vm.assume(buyerShare <= 100);
        
        // Setup
        vm.prank(MERCHANT);
        merchantRegistry.addMerchant(bytes32(uint256(1)));
        
        vm.startPrank(BUYER);
        token.approve(address(escrow), amount);
        uint256 orderId = escrow.createOrder(MERCHANT, amount, 7 days, "item");
        vm.stopPrank();
        
        // Buyer disputes
        vm.prank(BUYER);
        escrow.dispute(orderId, "issue");
        
        // DAO resolves
        uint256 buyerAmount = (amount * buyerShare) / 100;
        uint256 merchantAmount = amount - buyerAmount;
        
        address buyerVault = vaultHub.vaultOf(BUYER);
        address merchantVault = vaultHub.vaultOf(MERCHANT);
        
        uint256 buyerBalBefore = token.balanceOf(buyerVault);
        uint256 merchantBalBefore = token.balanceOf(merchantVault);
        
        vm.prank(DAO);
        escrow.resolve(orderId, buyerShare);
        
        uint256 buyerBalAfter = token.balanceOf(buyerVault);
        uint256 merchantBalAfter = token.balanceOf(merchantVault);
        
        assertEq(buyerBalAfter - buyerBalBefore, buyerAmount, "Buyer didn't receive correct amount");
        assertEq(merchantBalAfter - merchantBalBefore, merchantAmount, "Merchant didn't receive correct amount");
    }
    
    /// @notice Fuzz test: Cannot interact with order in wrong state
    function testFuzz_StateValidation(uint256 amount) public {
        vm.assume(amount > 0 && amount < 100_000e18);
        
        // Setup
        vm.prank(MERCHANT);
        merchantRegistry.addMerchant(bytes32(uint256(1)));
        
        vm.startPrank(BUYER);
        token.approve(address(escrow), amount);
        uint256 orderId = escrow.createOrder(MERCHANT, amount, 7 days, "item");
        vm.stopPrank();
        
        // Complete the order
        vm.prank(MERCHANT);
        escrow.complete(orderId);
        
        // Try to complete again
        vm.prank(MERCHANT);
        vm.expectRevert(COM_BadState.selector);
        escrow.complete(orderId);
        
        // Try to refund completed order
        vm.prank(BUYER);
        vm.expectRevert(COM_BadState.selector);
        escrow.refund(orderId);
    }
    
    /// @notice Fuzz test: Locked vaults cannot create orders
    function testFuzz_LockedVaultCannotCreateOrder(uint256 amount) public {
        vm.assume(amount > 0 && amount < 100_000e18);
        
        // Lock buyer's vault
        address buyerVault = vaultHub.vaultOf(BUYER);
        securityHub.setLocked(buyerVault, true);
        
        vm.prank(MERCHANT);
        merchantRegistry.addMerchant(bytes32(uint256(1)));
        
        vm.startPrank(BUYER);
        token.approve(address(escrow), amount);
        
        vm.expectRevert(COM_SecLocked.selector);
        escrow.createOrder(MERCHANT, amount, 7 days, "item");
        
        vm.stopPrank();
    }
    
    /// @notice Fuzz test: Multiple orders can exist simultaneously
    function testFuzz_MultipleSimultaneousOrders(uint8 numOrders) public {
        vm.assume(numOrders > 0 && numOrders <= 20);
        
        // Setup
        vm.prank(MERCHANT);
        merchantRegistry.addMerchant(bytes32(uint256(1)));
        
        uint256 amountEach = 100e18;
        uint256 totalNeeded = amountEach * numOrders;
        
        vm.startPrank(BUYER);
        token.approve(address(escrow), totalNeeded);
        
        uint256[] memory orderIds = new uint256[](numOrders);
        
        for (uint256 i = 0; i < numOrders; i++) {
            orderIds[i] = escrow.createOrder(MERCHANT, amountEach, 7 days, "item");
        }
        
        vm.stopPrank();
        
        // Verify all orders exist and are active
        for (uint256 i = 0; i < numOrders; i++) {
            (,,,,,, CommerceEscrow.State state,,,) = escrow.orders(orderIds[i]);
            assertEq(uint8(state), uint8(CommerceEscrow.State.ACTIVE), "Order should be active");
        }
        
        // Complete all orders
        vm.startPrank(MERCHANT);
        for (uint256 i = 0; i < numOrders; i++) {
            escrow.complete(orderIds[i]);
        }
        vm.stopPrank();
        
        // Verify merchant received total
        address merchantVault = vaultHub.vaultOf(MERCHANT);
        assertEq(token.balanceOf(merchantVault), totalNeeded, "Merchant didn't receive all payments");
    }
}
