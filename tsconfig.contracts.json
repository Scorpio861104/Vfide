{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "contracts/**/*.ts",
    "contracts/**/*.tsx",
    "config/**/*.ts",
    "config/**/*.tsx",
    "hardhat.config.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "coverage",
    "typechain-types",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
