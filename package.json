{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx --cache --cache-location .eslintcache",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "prepare": "husky .husky",
    "size": "size-limit",
    "check-circular": "madge --circular --extensions ts,tsx ./",
    "validate:env": "tsx lib/validateProduction.ts",
    "validate:production": "npm run typecheck && npm run lint && npm run test:ci && npm run validate:env",
    "prebuild": "npm run validate:env || true",
    "postinstall": "npm run validate:env || true",
    "contract:compile": "hardhat compile",
    "contract:test": "hardhat test",
    "contract:deploy": "hardhat run scripts/deploy.ts --network",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:init": "bash setup-database.sh",
    "migrate:up": "tsx lib/migrations/cli.ts up",
    "migrate:down": "tsx lib/migrations/cli.ts down",
    "migrate:status": "tsx lib/migrations/cli.ts status",
    "migrate:create": "tsx lib/migrations/cli.ts create",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci",
    "test:mobile": "jest --testPathPatterns mobile",
    "test:contract": "jest --testPathPatterns contract-interactions",
    "test:network": "jest --testPathPatterns network-resilience",
    "test:security": "jest --testPathPatterns security",
    "test:integration": "jest --testPathPatterns integration",
    "test:multichain": "jest --testPathPatterns multi-chain",
    "test:load": "jest --testPathPatterns load-stress",
    "test:accessibility": "jest --testPathPatterns accessibility",
    "test:websocket": "jest --testPathPatterns websocket",
    "test:storage": "jest --testPathPatterns storage",
    "test:error-boundary": "jest --testPathPatterns error-boundary",
    "test:performance:unit": "jest --testPathPatterns performance",
    "test:performance:e2e": "playwright test e2e/performance",
    "test:performance:all": "npm run test:performance:unit && npm run test:performance:e2e && npm run test:performance",
    "test:all": "npm run test && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "lhci autorun",
    "test:a11y": "jest --testPathPatterns=a11y --passWithNoTests",
    "test:a11y:watch": "jest --testPathPatterns=a11y --watch",
    "test:visual": "percy exec -- npm run test:e2e",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "circular-deps": "madge --circular --extensions ts,tsx ./",
    "size:why": "size-limit --why",
    "contract:analyze": "slither .",
    "contract:mythril": "sh -c \"if command -v myth >/dev/null 2>&1; then myth analyze contracts/VFIDETokenV2.sol; else docker run --rm -v $(pwd):/repo mythril/myth analyze /repo/contracts/VFIDETokenV2.sol; fi\"",
    "test:fuzz": "jest --testPathPattern=fuzz",
    "chromatic": "chromatic --exit-zero-on-changes",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "test:ui": "vitest --ui",
    "test:vitest": "vitest",
    "test:vitest:watch": "vitest --watch"
  },
  "dependencies": {
    "@datadog/browser-rum": "^6.25.4",
    "@datadog/browser-rum-react": "^6.25.4",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@sentry/nextjs": "^10.37.0",
    "@tanstack/react-query": "^5.90.20",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.29.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "next": "^16.1.5",
    "pg": "^8.17.2",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.4",
    "react-window": "^2.2.5",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "viem": "^2.45.0",
    "wagmi": "^2.19.5",
    "web-vitals": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@axe-core/react": "^4.11.0",
    "@chainlink/contracts": "^1.5.0",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@layerzerolabs/lz-evm-oapp-v2": "^3.0.156",
    "@layerzerolabs/lz-evm-protocol-v2": "^3.0.156",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.5",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.3",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@openzeppelin/contracts": "^4.9.6",
    "@percy/cli": "^1.31.8",
    "@playwright/test": "^1.58.0",
    "@size-limit/preset-app": "^12.0.0",
    "@storybook/addon-a11y": "^8.6.15",
    "@storybook/addon-essentials": "^8.6.15",
    "@storybook/addon-interactions": "^8.6.15",
    "@storybook/addon-links": "^8.6.15",
    "@storybook/addon-onboarding": "^8.6.15",
    "@storybook/addon-viewport": "^8.6.15",
    "@storybook/react-vite": "^8.6.15",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/chai": "^4.3.20",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "@uniswap/v3-core": "^1.0.1",
    "@uniswap/v3-periphery": "^1.4.4",
    "@vitest/ui": "^2.1.9",
    "ajv": "^8.17.1",
    "axe-core": "^4.11.1",
    "chromatic": "^13.3.5",
    "dotenv": "^16.6.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.5",
    "ethers": "^6.16.0",
    "fast-check": "^4.5.3",
    "hardhat": "^2.28.4",
    "hardhat-gas-reporter": "^2.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "lighthouse": "^13.0.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "minimatch": "^10.1.1",
    "msw": "^2.12.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "solidity-coverage": "^0.8.17",
    "storybook": "^8.6.15",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "^5",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "valtio": {
      "use-sync-external-store": "^1.2.2"
    },
    "use-sync-external-store": {
