{
  "name": "frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:contracts": "tsc -p tsconfig.contracts.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx --cache --cache-location .eslintcache",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:contracts": "prettier --write \"{scripts,__tests__/contracts}/**/*.{ts,js,json,md}\"",
    "format:check:contracts": "prettier --check \"{scripts,__tests__/contracts}/**/*.{ts,js,json,md}\"",
    "prepare": "husky .husky",
    "size": "size-limit",
    "check-circular": "madge --circular --extensions ts,tsx ./",
    "check:routes": "node scripts/check-route-alignment.mjs",
    "validate:env": "tsx lib/validateProduction.ts",
    "validate:production": "npm run typecheck && npm run typecheck:contracts && npm run lint && npm run test:ci && npm run validate:env",
    "prebuild": "npm run validate:env",
    "postinstall": "npm run validate:env || echo 'Warning: Environment validation failed. See above for details.'",
    "contract:compile": "hardhat compile",
    "contract:test": "hardhat test",
    "contract:verify:ocp-guardrails": "tsx scripts/verify-owner-controlpanel-guardrails.ts",
    "contract:verify:ocp-guardrails:local": "bash scripts/verify-ocp-guardrails-local.sh",
    "contract:verify:chain-of-return": "tsx scripts/verify-chain-of-return-timelock.ts",
    "contract:verify:chain-of-return:local": "bash scripts/verify-chain-of-return-local.sh",
    "contract:verify:next-of-kin": "tsx scripts/verify-next-of-kin-inheritance.ts",
    "contract:verify:next-of-kin:local": "bash scripts/verify-next-of-kin-local.sh",
    "contract:verify:proofscore-trust": "tsx scripts/verify-proofscore-trust-social-consistency.ts",
    "contract:verify:proofscore-trust:local": "bash scripts/verify-proofscore-trust-local.sh",
    "contract:verify:fee-burn-router": "tsx scripts/verify-fee-burn-router-invariants.ts",
    "contract:verify:fee-burn-router:local": "bash scripts/verify-fee-burn-router-local.sh",
    "contract:verify:ecosystem-work-rewards": "tsx scripts/verify-ecosystem-work-rewards-invariants.ts",
    "contract:verify:ecosystem-work-rewards:local": "bash scripts/verify-ecosystem-work-rewards-local.sh",
    "contract:verify:merchant-payment-escrow": "tsx scripts/verify-merchant-payment-escrow-invariants.ts",
    "contract:verify:merchant-payment-escrow:local": "bash scripts/verify-merchant-payment-escrow-local.sh",
    "contract:verify:bridge-governance": "tsx scripts/verify-bridge-governance-timelock.ts",
    "contract:verify:bridge-governance:local": "bash scripts/verify-bridge-governance-local.sh",
    "contract:verify:feature9:governance": "tsx scripts/verify-feature9-governance-timelock.ts",
    "contract:verify:feature9:governance:local": "bash scripts/verify-feature9-governance-local.sh",
    "contract:verify:governance-safety:local": "npm run -s contract:verify:ocp-guardrails:local && npm run -s contract:verify:chain-of-return:local && npm run -s contract:verify:next-of-kin:local && npm run -s contract:verify:feature9:governance:local",
    "contract:deploy": "hardhat run scripts/deploy.ts --network",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:init": "bash setup-database.sh",
    "migrate:up": "tsx lib/migrations/cli.ts up",
    "migrate:down": "tsx lib/migrations/cli.ts down",
    "migrate:status": "tsx lib/migrations/cli.ts status",
    "migrate:create": "tsx lib/migrations/cli.ts create",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci",
    "test:mobile": "jest --testPathPatterns mobile",
    "test:contract": "jest --testPathPatterns contract-interactions",
    "test:network": "jest --testPathPatterns network-resilience",
    "test:security": "jest --testPathPatterns security",
    "test:integration": "jest --testPathPatterns integration",
    "test:multichain": "jest --testPathPatterns multi-chain",
    "test:load": "jest --testPathPatterns load-stress",
    "test:accessibility": "jest --testPathPatterns accessibility",
    "test:websocket": "jest --testPathPatterns websocket",
    "test:storage": "jest --testPathPatterns storage",
    "test:error-boundary": "jest --testPathPatterns error-boundary",
    "test:performance:unit": "jest --testPathPatterns performance",
    "test:performance:e2e": "playwright test e2e/performance",
    "test:performance:all": "npm run test:performance:unit && npm run test:performance:e2e && npm run test:performance",
    "test:all": "npm run test && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "lhci autorun",
    "test:a11y": "jest --testPathPatterns=a11y --passWithNoTests",
    "test:a11y:watch": "jest --testPathPatterns=a11y --watch",
    "test:visual": "percy exec -- npm run test:e2e",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "circular-deps": "madge --circular --extensions ts,tsx ./",
    "size:why": "size-limit --why",
    "contract:analyze": "slither contracts --compile-force-framework solc --solc-args \"--via-ir --optimize --optimize-runs 200 --base-path . --include-path node_modules\" --filter-paths \"node_modules|test|mock\" --fail-none",
    "contract:analyze:strict": "slither contracts --compile-force-framework solc --solc-args \"--via-ir --optimize --optimize-runs 200 --base-path . --include-path node_modules\" --filter-paths \"node_modules|test|mock\" --fail-medium",
    "security:slither": "npm run -s contract:analyze:strict",
    "security:gate": "bash scripts/security-gate.sh",
    "security:report:replay": "tsx scripts/security-replay-metrics-report.ts",
    "test:fuzz": "jest --testPathPattern=fuzz",
    "chromatic": "chromatic --exit-zero-on-changes",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "test:ui": "vitest --ui",
    "test:vitest": "vitest",
    "test:vitest:watch": "vitest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@datadog/browser-rum": "^6.28.1",
    "@datadog/browser-rum-react": "^6.27.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@sentry/nextjs": "^10.37.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.2",
    "framer-motion": "^12.34.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.575.0",
    "next": "^16.1.5",
    "otplib": "^12.0.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.17.2",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-window": "^2.2.5",
    "recharts": "^3.8.0",
    "sharp": "^0.34.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "viem": "^2.47.0",
    "wagmi": "^2.19.5",
    "web-vitals": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@axe-core/react": "^4.11.0",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.4.0",
    "@layerzerolabs/lz-evm-oapp-v2": "^3.0.165",
    "@layerzerolabs/lz-evm-protocol-v2": "^3.0.162",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.5",
    "@nomicfoundation/hardhat-ethers": "^4.0.4",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.3",
    "@openzeppelin/contracts": "^5.4.0",
    "@percy/cli": "^1.31.8",
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-app": "^12.0.0",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-links": "^10.2.10",
    "@storybook/addon-onboarding": "^10.2.13",
    "@storybook/addon-viewport": "^9.0.8",
    "@storybook/react-vite": "^10.2.8",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/chai": "^5.2.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "@uniswap/v3-core": "^1.0.1",
    "@vitest/ui": "^4.0.18",
    "ajv": "^8.18.0",
    "axe-core": "^4.11.1",
    "chromatic": "^13.3.5",
    "dotenv": "^17.3.1",
    "eslint": "^10",
    "eslint-config-next": "^16.1.5",
    "eslint-plugin-react": "^7.37.5",
    "ethers": "^6.16.0",
    "fast-check": "^4.6.0",
    "hardhat": "3.1.7",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "lighthouse": "^13.0.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "minimatch": "^10.1.1",
    "msw": "^2.12.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.2.13",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typechain": "^8.3.2",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "valtio": {
      "use-sync-external-store": "^1.2.2"
    },
    "use-sync-external-store": {
      "react": "^19.2.3"
    },
    "tmp": "^0.2.4",
    "elliptic": "^6.6.1",
    "rollup": "^4.59.0",
    "minimatch": "^10.1.1",
    "test-exclude": {
      "minimatch": "^5.1.6"
    },
    "hono": "^4.11.10",
    "axios": "^1.13.5",
    "bn.js": "^5.2.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
