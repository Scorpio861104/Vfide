{
  "name": "vfide-hardhat-tests",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "FAST_TESTS=1 hardhat compile && FAST_TESTS=1 hardhat test --no-compile",
    "test:full": "hardhat compile && hardhat test --no-compile",
    "test:zksync": "hardhat test --network zkSyncSepoliaTestnet",
    "verify:zksync": "bash scripts/verify-zksync.sh",
    "zksync:node": "era_test_node --dev",
    "compile:zk": "hardhat compile --network zkSyncSepoliaTestnet",
    "compile:zk:local": "hardhat compile --network zkLocal",
    "test:zk:local": "hardhat test --network zkLocal",
    "deploy:zk:ledger": "hardhat deploy-zksync --script deploy/deploy-ledger.js --network zkSyncSepoliaTestnet",
    "deploy:zk:token": "hardhat deploy-zksync --script deploy/deploy-token.js --network zkSyncSepoliaTestnet",
    "deploy:zk:all": "hardhat deploy-zksync --script deploy/deploy-all.js --network zkSyncSepoliaTestnet",
    "verify:zk:ledger": "hardhat run --network zkSyncSepoliaTestnet scripts/verify-ledger.js",
    "verify:zk:token": "hardhat run --network zkSyncSepoliaTestnet scripts/verify-token.js",
    "verify:zk:all": "hardhat run --network zkSyncSepoliaTestnet scripts/verify-all.js",
    "deploy:zk:all:verify": "bash scripts/deploy-and-verify.sh",
    "diff:evm": "hardhat run --network hardhat scripts/diff/capture-token.js",
    "diff:local": "hardhat run --network zkLocal scripts/diff/capture-token.js",
    "diff:zk": "hardhat run --network zkSyncSepoliaTestnet scripts/diff/capture-token.js",
    "diff:compare": "node scripts/diff/compare.js",
    "diff:all": "npm run diff:evm && npm run diff:zk && npm run diff:compare",
    "diff:scenario:evm": "hardhat run --network hardhat scripts/diff/scenario-capture.js",
    "diff:scenario:zk": "hardhat run --network zkSyncSepoliaTestnet scripts/diff/scenario-capture.js",
    "diff:scenario:compare": "node scripts/diff/scenario-compare.js",
    "diff:scenario:all": "npm run diff:scenario:evm && npm run diff:scenario:zk && npm run diff:scenario:compare",
    "forge:coverage": "forge coverage --report lcov",
    "forge:snapshot": "forge snapshot",
    "coverage:check": "node scripts/coverage-check.js",
    "docgen": "solidity-docgen -i contracts-min -o docs",
    "slither": "slither . --config slither.config.json",
    "coverage": "COVERAGE=1 hardhat coverage",
    "coverage:fast": "FAST_TESTS=1 COVERAGE=1 hardhat coverage",
    "gas": "GAS_REPORT=1 hardhat test --no-compile",
    "size": "hardhat compile && hardhat size-contracts",
    "surya:graph": "surya graph contracts-min/*.sol | dot -Tpng > surya-graph.png",
    "lint:sol": "solhint 'contracts-min/**/*.sol'",
    "format": "prettier --write 'contracts-min/**/*.sol'",
    "aggregate": "bash scripts/aggregate.sh",
    "echidna": "echidna . --config echidna.yaml",
    "mythril:token": "docker run --rm -v $PWD:/proj -w /proj mythril/myth analyze contracts-min/VFIDEToken.sol --solv 0.8.30 || true",
    "medusa": "medusa --config medusa.json || true",
    "trip": "bash scripts/full-trip.sh"
  },
  "devDependencies": {
    "@matterlabs/hardhat-zksync-deploy": "^1.8.0",
    "@matterlabs/hardhat-zksync-node": "^1.5.3",
    "@matterlabs/hardhat-zksync-solc": "^1.5.1",
    "@matterlabs/hardhat-zksync-verify": "^1.9.1",
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@tenderly/hardhat-tenderly": "^2.5.2",
    "dotenv": "^17.2.3",
    "eslint": "^8.0.0",
    "hardhat": "^2.19.0",
    "hardhat-contract-sizer": "^2.10.1",
    "hardhat-gas-reporter": "^1.0.10",
    "hardhat-tracer": "^3.4.0",
    "solhint": "^6.0.1",
    "solhint-plugin-prettier": "^0.1.0",
    "solidity-coverage": "^0.8.6",
    "solidity-docgen": "^0.6.0-beta.36",
    "prettier": "^3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "surya": "^0.4.13",
    "zksync-ethers": "^6.21.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0"
  }
}
