{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --quiet --cache --cache-location .eslintcache \"app/**/*.{js,jsx,ts,tsx}\" \"components/**/*.{js,jsx,ts,tsx}\" \"hooks/**/*.{js,jsx,ts,tsx}\" \"lib/**/*.{js,jsx,ts,tsx}\"",
    "prepare": "husky",
    "size": "size-limit",
    "check-circular": "madge --circular --extensions ts,tsx ./",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci",
    "test:mobile": "jest --testPathPatterns mobile",
    "test:contract": "jest --testPathPatterns contract-interactions",
    "test:network": "jest --testPathPatterns network-resilience",
    "test:security": "jest --testPathPatterns security",
    "test:integration": "jest --testPathPatterns integration",
    "test:multichain": "jest --testPathPatterns multi-chain",
    "test:load": "jest --testPathPatterns load-stress",
    "test:accessibility": "jest --testPathPatterns accessibility",
    "test:websocket": "jest --testPathPatterns websocket",
    "test:storage": "jest --testPathPatterns storage",
    "test:error-boundary": "jest --testPathPatterns error-boundary",
    "test:all": "npm run test && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "lhci autorun",
    "test:a11y": "jest --testPathPatterns=a11y --passWithNoTests",
    "test:a11y:watch": "jest --testPathPatterns=a11y --watch",
    "test:visual": "percy exec -- npm run test:e2e",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "circular-deps": "madge --circular --extensions ts,tsx ./",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "prepare": "cd .. && husky frontend/.husky"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@rainbow-me/rainbowkit": "^2.2.9",
    "@tanstack/react-query": "^5.90.12",
    "@toruslabs/eccrypto": "^6.2.0",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.23.25",
    "lucide-react": "^0.555.0",
    "next": "^16.1.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.3",
    "react-window": "^2.2.4",
    "recharts": "^2.15.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "viem": "^2.41.2",
    "wagmi": "^2.19.5",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@axe-core/react": "^4.11.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.1",
    "@percy/cli": "^1.27.6",
    "@playwright/test": "^1.57.0",
    "@size-limit/preset-app": "^12.0.0",
    "@storybook/addon-a11y": "^8.6.15",
    "@storybook/addon-essentials": "^8.6.15",
    "@storybook/addon-interactions": "^8.6.15",
    "@storybook/addon-links": "^8.6.15",
    "@storybook/addon-onboarding": "^8.6.15",
    "@storybook/addon-viewport": "^8.6.15",
    "@storybook/react-vite": "^8.6.15",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "ajv": "^8.17.1",
    "axe-core": "^4.11.1",
    "chromatic": "^13.3.5",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "lighthouse": "^13.0.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "minimatch": "^10.1.1",
    "storybook": "^8.6.15",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "overrides": {
    "valtio": {
      "use-sync-external-store": "^1.2.2"
    },
    "use-sync-external-store": {
      "react": "^19.2.3"
    }
  }
}
