### package deployment scripts
build=next build
typecheck=tsc --noEmit
typecheck:contracts=tsc -p tsconfig.contracts.json --noEmit
lint=eslint . --ext .ts,.tsx --cache --cache-location .eslintcache
validate:env=tsx lib/validateProduction.ts
validate:production=npm run typecheck && npm run typecheck:contracts && npm run contract:verify:all && npm run check:abi-parity && npm run lint && npm run test:security:all && npm run test:integration && npm run validate:env && npm run check:eip1271
prebuild=npm run validate:env
contract:verify:deployment-graph=tsx scripts/verify-full-deployment-graph.ts
deploy:start-vesting:sepolia=hardhat run contracts/scripts/start-vesting.ts --network sepolia
deploy:start-vesting:mainnet=hardhat run contracts/scripts/start-vesting.ts --network mainnet
deploy:arm-handover:sepolia=hardhat run contracts/scripts/arm-handover.ts --network sepolia
deploy:arm-handover:mainnet=hardhat run contracts/scripts/arm-handover.ts --network mainnet
deploy:full=hardhat run scripts/deploy-full.ts --network
deploy:phase1=hardhat run contracts/scripts/deploy-phase1.ts --network
deploy:phase2=hardhat run scripts/future/deploy-phase2.ts --network
deploy:phase3=hardhat run scripts/future/deploy-phase3.ts --network
deploy:phase4=hardhat run scripts/future/deploy-phase4.ts --network
deploy:phase5=hardhat run scripts/future/deploy-phase5.ts --network
validate:phase1:deploy=hardhat run scripts/validate-phase1-dry-run.ts
test:onchain:deploy-integration=VFIDE_RUN_DEPLOY_INTEGRATION=true HARDHAT_ALLOW_UNLIMITED_CONTRACT_SIZE=true npx hardhat test test/contracts/DeployFullIntegration.test.ts
test:ci=jest --coverage --ci && npm run -s test:signatures && npm run -s contract:verify:frontend-guardrails && npm run -s contract:verify:frontend-abi-parity
build:storybook=storybook build
ops:release:stop-go=tsx scripts/verify-release-stop-go.ts
security:gate=bash scripts/security-gate.sh
validate:deploy=tsx scripts/validate-deployment.ts --force-continue
deploy:full:apply=hardhat run scripts/apply-full.ts --network
validate:testnet=hardhat run scripts/validate-testnet-ready.ts --network
validate:frontend=tsx scripts/validate-frontend-ready.ts
