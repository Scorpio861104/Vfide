# Production Environment - WebSocket Server
# Copy this file to .env.production for production deployments

# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# CORS Configuration
CORS_ORIGIN=https://vfide.io
CORS_METHODS=GET,POST
CORS_CREDENTIALS=true

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=vfide:prod:

# Authentication
JWT_SECRET=
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_CHAT_MAX=50

# WebSocket Configuration
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=60000
WS_MAX_HTTP_BUFFER_SIZE=1e6
WS_TRANSPORTS=websocket,polling

# Blockchain
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453
DAO_ADDRESS=
TOKEN_ADDRESS=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/var/log/vfide/websocket.log
LOG_MAX_FILES=30

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Performance
MAX_CONNECTIONS=1000
MAX_ROOMS_PER_USER=10
MESSAGE_QUEUE_SIZE=1000

# Security
ENABLE_IP_WHITELIST=false
IP_WHITELIST=
ENABLE_SIGNATURE_VERIFICATION=true
