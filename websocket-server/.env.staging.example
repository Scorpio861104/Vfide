# Staging Environment - WebSocket Server
# Copy this file to .env.staging for staging deployments

# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# CORS Configuration
CORS_ORIGIN=https://staging.vfide.io
CORS_METHODS=GET,POST
CORS_CREDENTIALS=true

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_KEY_PREFIX=vfide:staging:

# Authentication
JWT_SECRET=
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Rate Limiting (more lenient for testing)
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_CHAT_MAX=100

# WebSocket Configuration
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=60000
WS_MAX_HTTP_BUFFER_SIZE=1e6
WS_TRANSPORTS=websocket,polling

# Blockchain
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532
DAO_ADDRESS=
TOKEN_ADDRESS=

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=/var/log/vfide/websocket-staging.log
LOG_MAX_FILES=14

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=1.0

# Performance
MAX_CONNECTIONS=500
MAX_ROOMS_PER_USER=20
MESSAGE_QUEUE_SIZE=500

# Security
ENABLE_IP_WHITELIST=false
IP_WHITELIST=
ENABLE_SIGNATURE_VERIFICATION=true

# Debug (staging only)
ENABLE_DEBUG_LOGS=true
ENABLE_PROFILING=true
