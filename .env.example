# ============================================
# VFIDE Smart Contract Deployment Configuration
# ============================================
# This file is for smart contract deployment only.
# Frontend and WebSocket configurations are in their respective directories.

# ============================================
# REQUIRED: Deployment Wallet Private Key
# ============================================
# Get testnet ETH from: https://sepoliafaucet.com/
# Bridge to zkSync: https://portal.zksync.io/bridge
# ⚠️ NEVER commit this file with real private keys!
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ============================================
# OPTIONAL: Custom RPC URLs
# ============================================
# If not set, defaults from hardhat.config.js and foundry.toml will be used

# Ethereum Networks
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# zkSync Networks
# ZKSYNC_SEPOLIA_RPC=https://sepolia.era.zksync.dev
# ZKSYNC_MAINNET_RPC=https://mainnet.era.zksync.io

# Base Networks (Coinbase L2)
# BASE_RPC_URL=https://mainnet.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Polygon Networks
# POLYGON_RPC_URL=https://polygon-rpc.com
# POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ============================================
# OPTIONAL: Block Explorer API Keys (for verification)
# ============================================
# Get your keys from:
# - Etherscan: https://etherscan.io/apis
# - BaseScan: https://basescan.org/apis
# - Polygonscan: https://polygonscan.com/apis

# ETHERSCAN_API_KEY=your_etherscan_api_key
# BASESCAN_API_KEY=your_basescan_api_key
# POLYGONSCAN_API_KEY=your_polygonscan_api_key
# ZKSYNC_EXPLORER_API_KEY=your_zksync_explorer_key

# ============================================
# OPTIONAL: Gas Price Settings
# ============================================
# GAS_PRICE=auto
# GAS_LIMIT=8000000

# ============================================
# OPTIONAL: Deployment Configuration
# ============================================
# DEPLOY_VERIFY=true
# DEPLOY_CONFIRM=true

# ============================================
# OPTIONAL: CoinMarketCap API (for gas reporting in USD)
# ============================================
# CMC_API_KEY=your_coinmarketcap_api_key

# ============================================
# NOTES:
# ============================================
# 1. Copy this file: DO NOT edit .env.example directly
# 2. For production: Use hardware wallet or secure key management
# 3. Test on testnet first: Base Sepolia, Polygon Amoy, zkSync Sepolia
# 4. Verify contracts after deployment for transparency
# 5. Document all deployed addresses in a secure location
