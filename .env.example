# Environment Variables for VFIDE Deployment

# Deployment Wallet Private Key (without 0x prefix)
# Get testnet ETH from: https://sepoliafaucet.com/
# Bridge to zkSync: https://portal.zksync.io/bridge
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Optional: RPC URLs (defaults are provided in hardhat.config.js)
# ZKSYNC_SEPOLIA_RPC=https://sepolia.era.zksync.dev
# ZKSYNC_MAINNET_RPC=https://mainnet.era.zksync.io

# Optional: Block Explorer API Keys for Verification
# ETHERSCAN_API_KEY=your_etherscan_api_key
# ZKSYNC_EXPLORER_API_KEY=your_zksync_explorer_key

# Optional: Gas Price Settings
# GAS_PRICE=auto
# GAS_LIMIT=8000000

# Optional: Deployment Configuration
# DEPLOY_VERIFY=true
# DEPLOY_CONFIRM=true
