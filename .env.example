# ============================================
# VFIDE Smart Contract Deployment Configuration
# ============================================
# This file is for smart contract deployment only.
# Frontend and WebSocket configurations are in their respective directories.

# ============================================
# REQUIRED: Deployment Wallet Private Key
# ============================================
# Get testnet ETH from: https://sepoliafaucet.com/
# Bridge to zkSync: https://portal.zksync.io/bridge
# ⚠️ NEVER commit this file with real private keys!
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ============================================
# OPTIONAL: Custom RPC URLs
# ============================================
# If not set, defaults from hardhat.config.js and foundry.toml will be used

# Ethereum Networks
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# zkSync Networks
# ZKSYNC_SEPOLIA_RPC=https://sepolia.era.zksync.dev
# ZKSYNC_MAINNET_RPC=https://mainnet.era.zksync.io

# Base Networks (Coinbase L2)
# BASE_RPC_URL=https://mainnet.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Polygon Networks
# POLYGON_RPC_URL=https://polygon-rpc.com
# POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ============================================
# OPTIONAL: Block Explorer API Keys (for verification)
# ============================================
# Get your keys from:
# - Etherscan: https://etherscan.io/apis
# - BaseScan: https://basescan.org/apis
# - Polygonscan: https://polygonscan.com/apis

# ETHERSCAN_API_KEY=your_etherscan_api_key
# BASESCAN_API_KEY=your_basescan_api_key
# POLYGONSCAN_API_KEY=your_polygonscan_api_key
# ZKSYNC_EXPLORER_API_KEY=your_zksync_explorer_key

# ============================================
# OPTIONAL: Gas Price Settings
# ============================================
# GAS_PRICE=auto
# GAS_LIMIT=8000000

# ============================================
# OPTIONAL: Deployment Configuration
# ============================================
# DEPLOY_VERIFY=true
# DEPLOY_CONFIRM=true

# ============================================
# OPTIONAL: CoinMarketCap API (for gas reporting in USD)
# ============================================
# CMC_API_KEY=your_coinmarketcap_api_key

# ============================================
# FIAT ON-RAMP PROVIDERS (for /buy page)
# ============================================
# Required to show fiat-to-crypto purchase options. Leave blank to hide provider.
# NEXT_PUBLIC_MOONPAY_API_KEY=pk_live_...
# NEXT_PUBLIC_TRANSAK_API_KEY=...
# NEXT_PUBLIC_RAMP_API_KEY=...

# ============================================
# EMAIL / NOTIFICATIONS
# ============================================
# Required for support ticket emails and system notifications.
# SENDGRID_API_KEY=SG....

# ============================================
# PHASE 1 SECURITY ENHANCEMENTS CONFIGURATION
# ============================================
# Required for Phase 1 deployment (deploy-phase1.ts)

# Admin address (should be governance/DAO timelock or multisig)
# ADMIN_ADDRESS=0x...

# Council Members (exactly 5 required for AdminMultiSig)
# COUNCIL_MEMBER_1=0x...
# COUNCIL_MEMBER_2=0x...
# COUNCIL_MEMBER_3=0x...
# COUNCIL_MEMBER_4=0x...
# COUNCIL_MEMBER_5=0x...

# Price Oracle address (used by CircuitBreaker)
# PRICE_ORACLE_ADDRESS=0x...

# Pre-deployed contract addresses required by VFIDEToken constructor.
# Deploy these BEFORE running deploy-phase1.ts (or use TempVault placeholders
# and transfer token allocations afterward):
# DEV_RESERVE_VESTING_VAULT=0x...   # DevReserveVestingVault (receives 50M VFIDE)
# TREASURY_ADDRESS=0x...             # Treasury EOA or multisig (receives 150M VFIDE - includes former presale allocation)

# Optional modules (can be zero — set after deployment via OCP):
# VAULT_HUB_ADDRESS=0x...
# PROOF_LEDGER_ADDRESS=0x...
# TREASURY_SINK_ADDRESS=0x...        # EcoTreasuryVault or RevenueSplitter

# Optional: if VFIDEToken is already deployed (upgrade/patch scenario), pass it here
# so AdminMultiSig can enforce token-stake-gated community veto (H-05 fix):
# VFIDE_TOKEN=0x...

# Role Assignments (comma-separated addresses)
# PAUSERS=0x...,0x...
# BLACKLIST_MANAGERS=0x...,0x...
# CONFIG_MANAGERS=0x...,0x...

# ============================================
# PHASE 3 BRIDGE & ORACLE CONFIGURATION
# ============================================
# Required for Phase 3 deployment (deploy-phase3.ts)
# Deploy Phase 1 first, then set these before running Phase 3.

# VFIDE_TOKEN=0x...                  # Deployed VFIDEToken address
# LAYERZERO_ENDPOINT=0x...           # LayerZero V2 endpoint for target chain
#   Base mainnet:    0x1a44076050125825900e736c501f859c50fE728c
#   Polygon mainnet: 0x1a44076050125825900e736c501f859c50fE728c
#   zkSync Era:      0x6F475642a6e85809B1c36Fa62763669b1b48DD5B
# QUOTE_TOKEN=0x...                  # USDC or stablecoin used as price reference
# OWNER_ADDRESS=0x...                # Owner for bridge + oracle contracts (same as ADMIN_ADDRESS)

# Optional oracle sources (zero address = disabled):
# CHAINLINK_FEED=0x...
# UNISWAP_POOL=0x...

# Gas Reporting
# REPORT_GAS=true

# ============================================
# NOTES:
# ============================================
# 1. Copy this file to .env — NEVER commit .env with real keys!
# 2. For production: Use hardware wallet or secure key management (e.g., AWS KMS)
# 3. Test on testnets first: Base Sepolia, Polygon Amoy, zkSync Sepolia
# 4. Deployment order:
#    a. Deploy TempVault for dev reserve placeholder (if needed)
#    b. Deploy VFIDEToken (mints 200M, sends to TempVault and Treasury)
#    c. Deploy DevReserveVestingVault with real token address
#    d. Transfer 50M from TempVault-dev → DevReserveVestingVault
#    e. Run deploy-phase1.ts (deploys AccessControl, MultiSig, security infra)
#    f. Run deploy-phase3.ts (deploys Bridge + Oracle)
# 5. Verify contracts on block explorer after deployment
# 6. Document all deployed addresses in a secure, auditable location
