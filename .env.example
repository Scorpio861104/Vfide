# zkSync & Tooling Environment Example

# Deployer private key (hex, with 0x). Must be funded on zkSync Sepolia for testnet deploys.
PRIVATE_KEY=0xabc123...

# RPC endpoints (optional; hardhat.config.js has sensible defaults)
MAINNET_RPC_URL=https://mainnet.infura.io/v3/your-key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-key
ZKSYNC_SEPOLIA_RPC_URL=https://sepolia.era.zksync.dev
ZKSYNC_MAINNET_RPC_URL=https://mainnet.era.zksync.io

# Gas reporter (optional)
CMC_API_KEY=your_coinmarketcap_api_key
GAS_REPORT=
ZKSYNC_GAS_PRICE_GWEI=0.25

# Enable zkSync verify plugin tasks (optional)
ZKSYNC_VERIFY=

# Optional: DAO address to use as ProofLedger constructor arg (defaults to deployer)
DAO_ADDRESS=

# VFIDEToken deployment (provide real addresses for production)
# If DEV_VESTING_VAULT is not set, the deploy script will create a test-only mock vault.
DEV_VESTING_VAULT=
VAULT_HUB=
LEDGER=
TREASURY_SINK=
