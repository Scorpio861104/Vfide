# =============================================================================
# VFIDE Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or any file with real credentials to git
# =============================================================================

# -----------------------------------------------------------------------------
# WalletConnect Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get your free Project ID at: https://cloud.walletconnect.com/
# Required for proper wallet connection functionality (MetaMask, mobile wallets, etc.)
# Without this, only Coinbase Wallet will work properly
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
# Set to 'true' for testnet, 'false' for mainnet (default: testnet)
NEXT_PUBLIC_IS_TESTNET=true

# RPC Endpoints (Optional - uses public RPCs if not set)
# Get free RPC endpoints from Alchemy, Infura, or QuickNode
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com
NEXT_PUBLIC_POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
NEXT_PUBLIC_ZKSYNC_RPC_URL=https://mainnet.era.zksync.io
NEXT_PUBLIC_ZKSYNC_SEPOLIA_RPC_URL=https://sepolia.era.zksync.dev

# -----------------------------------------------------------------------------
# Monitoring & Error Tracking (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking - Get from https://sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry Configuration
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# -----------------------------------------------------------------------------
# Database Configuration (Optional - for advanced features)
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/vfide

# -----------------------------------------------------------------------------
# API Configuration (Optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_FEATURE_NEW_DASHBOARD=false
# NEXT_PUBLIC_FEATURE_BETA_STAKING=false
# NEXT_PUBLIC_FEATURE_ADVANCED_CHARTS=false

# -----------------------------------------------------------------------------
# Security (Optional but recommended for production)
# -----------------------------------------------------------------------------
# SESSION_SECRET=your-secret-key-min-32-characters-long
# JWT_SECRET=your-jwt-secret-key-min-32-characters

# Rate Limiting (with Upstash Redis)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Email Configuration (Optional)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@vfide.com

# -----------------------------------------------------------------------------
# Contract Addresses (Auto-configured per network)
# -----------------------------------------------------------------------------
# Override specific contract addresses if needed
# NEXT_PUBLIC_VFIDE_TOKEN_ADDRESS=
# NEXT_PUBLIC_ESCROW_MANAGER_ADDRESS=
# NEXT_PUBLIC_DAO_ADDRESS=

# -----------------------------------------------------------------------------
# Development Tools (Development only)
# -----------------------------------------------------------------------------
# ANALYZE=true                    # Enable bundle analyzer
# NEXT_TELEMETRY_DISABLED=1      # Disable Next.js telemetry
