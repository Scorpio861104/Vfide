{
  "detectors_to_exclude": "naming-convention,solc-version,dead-code,low-level-calls,missing-inheritance,unindexed-event-address,cache-array-length,constable-states,immutable-states,unused-return,divide-before-multiply,incorrect-equality,unchecked-transfer,calls-loop,costly-loop,timestamp,uninitialized-local,reentrancy-no-eth,reentrancy-balance,arbitrary-send-erc20,write-after-write,uninitialized-state",
  "filter_paths": "node_modules|test|mock",
  "exclude_informational": true,
  "exclude_low": true,
  "exclude_medium": false,
  "exclude_high": false,
  "solc_remaps": [
    "@openzeppelin=node_modules/@openzeppelin",
    "hardhat=node_modules/hardhat"
  ]
}
