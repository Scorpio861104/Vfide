{
  "detectors_to_exclude": "arbitrary-send-erc20,assembly,calls-loop,constable-states,costly-loop,cyclomatic-complexity,dead-code,divide-before-multiply,external-function,immutable-states,incorrect-equality,low-level-calls,missing-inheritance,missing-zero-check,naming-convention,redundant-statements,reentrancy-balance,reentrancy-benign,reentrancy-eth,reentrancy-events,reentrancy-no-eth,shadowing-local,similar-names,solc-version,timestamp,too-many-digits,unchecked-transfer,unindexed-event-address,uninitialized-state,unused-return",
