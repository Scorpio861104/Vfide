ler(address,bool)\":{\"notice\":\"Set authorized caller (CommerceEscrow contract)\"},\"setBenefitRates(uint16,uint16)\":{\"notice\":\"Set ProofScore reward rates (DAO only)\"},\"setEcosystemVault(address)\":{\"notice\":\"Set EcosystemVault for merchant bonuses\"}},\"notice\":\"Rewards VFIDE users for commerce activity with FREE ProofScore boosts  Philosophy: - Free incentives only - no circular cashback funded by fees - ProofScore is free reputation that costs nothing to award - High-trust merchants get VFIDE bonus (from ecosystem pool, not buyers) - Merchants get 100% of payments (0% platform fee)  Commerce flow: 1. Buyer opens escrow with VFIDE 2. Buyer funds escrow 3. Merchant delivers goods/services 4. Buyer releases funds \\u2192 Merchant gets 100% 5. VFIDEBenefits awards:    - FREE ProofScore to both parties    - 1 VFIDE bonus to high-trust merchants (from ecosystem pool)\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"contracts/VFIDEBenefits.sol\":\"VFIDEBenefits\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":20},\"remappings\":[\":@openzeppelin/=node_modules/@openzeppelin/\",\":eth-gas-reporter/=node_modules/eth-gas-reporter/\",\":forge-std/=lib/forge-std/src/\",\":hardhat/=node_modules/hardhat/\"],\"viaIR\":true},\"sources\":{\"contracts/SharedInterfaces.sol\":{\"keccak256\":\"0x5bea3e8bcdbc5d846dcb751b0e2526031f9818ebadf687bfd4361a905b03b027\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://1fd5a306407ced7b3f7c4474c78a8180e26b61c5330a870e3ba25071cdd34f4b\",\"dweb:/ipfs/QmV5WqZG5UoCh8mZWEien7e8j2Ch3HTiXRedtfHFPk9ToQ\"]},\"contracts/VFIDEBenefits.sol\":{\"keccak256\":\"0x1ea94184d0f0067c491b932736cafe4d5cbe83a6c7d75a8b1c17b318ac06ed52\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://44478b14ed93d7df356b0fea7f9fb49812dbf3b43e0a5ee1d1dba851ffee7218\",\"dweb:/ipfs/QmR2CVxGS1PUCrgcUbCT4scZ1nDmfEyXC5jdmG3AENqatL\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.30+commit.7371