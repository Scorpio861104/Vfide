er)</font></TD></TR><TR><TD align="left">    securityHub<font color="blue" POINT-SIZE="10"> (ISecurityHub)</font></TD></TR><TR><TD align="left">    ledger<font color="blue" POINT-SIZE="10"> (IProofLedger)</font></TD></TR><TR><TD align="left">    rebateVault<font color="blue" POINT-SIZE="10"> (IMerchantRebateVault)</font></TD></TR><TR><TD align="left">    rebateScoreThreshold</TD></TR><TR><TD align="left">    dao</TD></TR><TR><TD align="left">    protocolFeeBps</TD></TR><TR><TD align="left">    feeSink</TD></TR><TR><TD align="left">    minMerchantScore</TD></TR><TR><TD align="left">    merchants</TD></TR><TR><TD align="left">    merchantList</TD></TR><TR><TD align="left">    acceptedTokens</TD></TR><TR><TD align="left">    swapRouter<font color="blue" POINT-SIZE="10"> (ISwapRouter)</font></TD></TR><TR><TD align="left">    stablecoin</TD></TR><TR><TD align="left">    autoConvert</TD></TR></TABLE> >];

