{
  "name": "vfide-smart-contracts",
  "version": "1.0.0",
  "description": "VFIDE Phase 1 Security Enhanced Smart Contracts",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:sepolia": "hardhat run contracts/scripts/deploy-phase1.ts --network sepolia",
    "deploy:mainnet": "hardhat run contracts/scripts/deploy-phase1.ts --network mainnet",
    "verify:sepolia": "hardhat run contracts/scripts/verify-phase1.ts --network sepolia",
    "verify:mainnet": "hardhat run contracts/scripts/verify-phase1.ts --network mainnet",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "format:sol": "prettier --write 'contracts/**/*.sol'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.1",
    "hardhat": "^2.19.5",
    "hardhat-gas-reporter": "^1.0.9",
    "solhint": "^4.1.1",
    "solidity-coverage": "^0.8.5",
    "prettier": "^3.2.4",
    "prettier-plugin-solidity": "^1.3.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.1"
  },
  "keywords": [
    "vfide",
    "security",
    "smart-contracts",
    "defi",
    "ethereum",
    "solidity"
  ],
  "author": "VFIDE Team",
  "license": "MIT"
}
