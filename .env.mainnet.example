# VFIDE mainnet environment example
# Copy to your secret store / .env.production and fill with real values.
# Do NOT commit real keys.

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://app.vfide.io
NEXT_PUBLIC_API_URL=https://api.vfide.io
NEXT_PUBLIC_WEBSOCKET_URL=wss://ws.vfide.io

# Core chain / RPC
NEXT_PUBLIC_DEPLOYMENT_CHAIN_ID=8453
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ZKSYNC_MAINNET_RPC_URL=https://mainnet.era.zksync.io

# Public contract addresses
NEXT_PUBLIC_VFIDE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STABLECOIN_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_HUB_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DAO_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SEER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VFIDE_COMMERCE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MERCHANT_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BURN_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PROOF_LEDGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_OWNER_CONTROL_PANEL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PAYROLL_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SUBSCRIPTION_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SANCTUM_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DEV_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ECOSYSTEM_VAULT_VIEW_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ESCROW_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FEE_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_WITHDRAWAL_QUEUE_ADDRESS=0x0000000000000000000000000000000000000000

# Backend / auth
DATABASE_URL=postgresql://user:password@db-host:5432/vfide
JWT_SECRET=replace-with-a-strong-random-secret
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=replace-me
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Wallet / web3
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=replace-me
NEXT_PUBLIC_WAGMI_PROJECT_ID=replace-me

# Deploy / treasury addresses
DAO_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
BENEFICIARY_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_SINK_ADDRESS=0x0000000000000000000000000000000000000000
SANCTUM_SINK_ADDRESS=0x0000000000000000000000000000000000000000
ECOSYSTEM_SINK_ADDRESS=0x0000000000000000000000000000000000000000
BURN_SINK_ADDRESS=0x0000000000000000000000000000000000000000
DAO_PAYROLL_SINK_ADDRESS=0x0000000000000000000000000000000000000000
MERCHANT_POOL_SINK_ADDRESS=0x0000000000000000000000000000000000000000
HEADHUNTER_POOL_SINK_ADDRESS=0x0000000000000000000000000000000000000000
FEE_SINK_ADDRESS=0x0000000000000000000000000000000000000000
VERIFY_CONTRACTS=false
DEPLOY_TESTNET_FAUCET=false

# Optional storage / messaging
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_PUBLIC_BASE_URL=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
