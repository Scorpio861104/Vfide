# Staging Environment Configuration
# Copy this file to .env.staging for staging deployments

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=VFIDE (Staging)
NEXT_PUBLIC_APP_URL=https://staging.vfide.io

# Blockchain Configuration
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_EXPLORER_URL=https://sepolia.basescan.org

# Smart Contract Addresses (Base Sepolia testnet)
NEXT_PUBLIC_DAO_ADDRESS=
NEXT_PUBLIC_TOKEN_ADDRESS=
NEXT_PUBLIC_TIMELOCK_ADDRESS=
NEXT_PUBLIC_GOVERNOR_ADDRESS=
NEXT_PUBLIC_TREASURY_ADDRESS=
NEXT_PUBLIC_BADGE_REGISTRY_ADDRESS=
NEXT_PUBLIC_COUNCIL_MANAGER_ADDRESS=

# WebSocket Server
NEXT_PUBLIC_WEBSOCKET_URL=wss://ws-staging.vfide.io
NEXT_PUBLIC_WEBSOCKET_PATH=/socket.io

# API Configuration
NEXT_PUBLIC_API_URL=https://api-staging.vfide.io
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_GOVERNANCE=true
NEXT_PUBLIC_ENABLE_COUNCIL=true
NEXT_PUBLIC_ENABLE_BADGES=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_DEBUG_TOOLS=true

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=staging

# Social Links
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/vfide
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/vfide
NEXT_PUBLIC_GITHUB_URL=https://github.com/Scorpio861104/Vfide

# Performance
NEXT_PUBLIC_ENABLE_PWA=false
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=false

# Security
NEXT_PUBLIC_CSP_ENABLED=true
NEXT_PUBLIC_RATE_LIMIT_ENABLED=true

# Development Tools (staging only)
NEXT_PUBLIC_SHOW_GRID=false
NEXT_PUBLIC_SHOW_BREAKPOINTS=false
