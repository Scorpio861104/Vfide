# ─────────────────────────────────────────────────────────────────────────────
# VFIDE Testnet (Base Sepolia) — deploy environment
# Copy to .env and fill in real values before running deploy-full.ts
# ⚠️  NEVER commit a file containing a real PRIVATE_KEY
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployer ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=<testnet_private_key_no_0x>

# ── Network ───────────────────────────────────────────────────────────────────
# Optional — defaults to public RPC if unset
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Bootstrap addresses ───────────────────────────────────────────────────────
# On testnet these can all be the same address (your deployer wallet).
# On mainnet they MUST be separate multisigs.
BOOTSTRAP_ADMIN_ADDRESS=0x<deployer>
BOOTSTRAP_DAO_ADDRESS=0x<deployer>
BOOTSTRAP_BENEFICIARY_ADDRESS=0x<deployer>
BOOTSTRAP_TREASURY_SINK_ADDRESS=0x<deployer>
BOOTSTRAP_SANCTUM_SINK_ADDRESS=0x<deployer>
BOOTSTRAP_BURN_SINK_ADDRESS=0x<deployer>
BOOTSTRAP_ECOSYSTEM_SINK_ADDRESS=0x<deployer>
BOOTSTRAP_POOL_ADMIN_ADDRESS=0x<deployer>
BOOTSTRAP_FAUCET_OWNER_ADDRESS=0x<deployer>
BOOTSTRAP_LEDGER_ADMIN_ADDRESS=0x<deployer>

# Allows bootstrap addresses to equal the deployer (testnet only)
ALLOW_TEMPORARY_DEPLOYER_BOOTSTRAP=true

# ── VFIDEPriceOracle constructor args ─────────────────────────────────────────
# 4-element JSON array: [quoteToken, chainlinkFeed, uniswapPool, owner]
# Use address(0) for chainlinkFeed and uniswapPool on testnet.
# quoteToken: a testnet USDC-equivalent address (or deployer wallet for a smoke test)
ARGS_VFIDEPRICEORACLE='["0x<testnet_usdc_or_any_erc20>","0x0000000000000000000000000000000000000000","0x0000000000000000000000000000000000000000","0x<owner>"]'

# ── Faucet ────────────────────────────────────────────────────────────────────
DEPLOY_TESTNET_FAUCET=true

# ── Contract verification (optional) ─────────────────────────────────────────
# VERIFY_CONTRACTS=true
# BASESCAN_API_KEY=<your_basescan_api_key>

# ── Frontend contract addresses (fill AFTER deploy from DeploymentBook output) ──
NEXT_PUBLIC_DEPLOYMENT_CHAIN_ID=84532
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_VFIDE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_HUB_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SEER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MERCHANT_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BURN_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DAO_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DAO_TIMELOCK_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FEE_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PROOF_LEDGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ECOSYSTEM_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ECOSYSTEM_VAULT_VIEW_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COMMERCE_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MERCHANT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SANCTUM_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FRAUD_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_RECOVERY_CLAIM_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FLASH_LOAN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TERM_LOAN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GOVERNANCE_HOOKS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PAYROLL_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LIQUIDITY_INCENTIVES_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FAUCET_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CARD_BOUND_VAULT_DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8080

# ── Auth / DB (testnet) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vfide_testnet
JWT_SECRET=replace-with-32-char-random-secret
LOG_IP_HASH_SALT=replace-with-16-char-salt
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me
USSD_GATEWAY_TOKEN=testnet-token
ALLOW_MOCK_USSD=true
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=replace-me
